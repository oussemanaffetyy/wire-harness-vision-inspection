[
  {
    "id": "whi_tab",
    "type": "tab",
    "label": "Wire Harness Inspection",
    "disabled": false,
    "info": ""
  },
  {
    "id": "whi_broker",
    "type": "mqtt-broker",
    "name": "Local MQTT",
    "broker": "127.0.0.1",
    "port": "1883",
    "clientid": "wire-harness-inspector",
    "autoConnect": true,
    "usetls": false,
    "protocolVersion": "4",
    "keepalive": "60",
    "cleansession": true
  },
  {
    "id": "whi_ui",
    "type": "ui-base",
    "name": "Inspection Dashboard",
    "path": "/inspection",
    "includeClientData": true,
    "showSearch": false,
    "showTabs": true,
    "showHeader": true,
    "homeMenu": false
  },
  {
    "id": "whi_theme",
    "type": "ui-theme",
    "name": "Dark Theme",
    "colors": {
      "surface": "#1a1a1a",
      "primary": "#214E6A",
      "bgPage": "#1a1a1a",
      "groupBg": "#2a2a2a",
      "groupOutline": "#404040"
    }
  },
  {
    "id": "whi_page",
    "type": "ui-page",
    "name": "Live Dashboard",
    "ui": "whi_ui",
    "path": "/",
    "layout": "grid",
    "theme": "whi_theme",
    "order": 1
  },
  {
    "id": "whi_group_video",
    "type": "ui-group",
    "name": "Video Stream",
    "page": "whi_page",
    "width": 6,
    "height": 10,
    "order": 1
  },
  {
    "id": "whi_group_info",
    "type": "ui-group",
    "name": "System Status",
    "page": "whi_page",
    "width": 6,
    "height": 10,
    "order": 2
  },
  {
    "id": "whi_mqtt_video",
    "type": "mqtt in",
    "z": "whi_tab",
    "name": "Video Stream MQTT",
    "topic": "factory/inspection/video_stream",
    "qos": "0",
    "datatype": "json",
    "broker": "whi_broker",
    "nl": false,
    "rap": false,
    "rh": 0,
    "inputs": 0,
    "x": 170,
    "y": 100,
    "wires": [["whi_video_display"]]
  },
  {
    "id": "whi_video_display",
    "type": "ui-template",
    "z": "whi_tab",
    "group": "whi_group_video",
    "name": "Video Display",
    "order": 1,
    "width": 6,
    "height": 10,
    "format": "<template>\n  <div class=\"whi-video-card\">\n    <img\n      v-if=\"p.image_base64\"\n      class=\"whi-video-image\"\n      :src=\"'data:image/jpeg;base64,' + p.image_base64\"\n      alt=\"Video stream\"\n    />\n    <div v-else class=\"whi-video-placeholder\">Waiting for video stream...</div>\n  </div>\n</template>\n<style>\n.whi-video-card {\n  width: 100%;\n  height: 100%;\n  min-height: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  overflow: hidden;\n  background: #000;\n  border-radius: 10px;\n}\n.whi-video-image {\n  width: 100%;\n  height: 100%;\n  object-fit: contain;\n  display: block;\n}\n.whi-video-placeholder {\n  color: #9aa7b5;\n  font-size: 16px;\n  text-align: center;\n  padding: 16px;\n}\n</style>\n<script>\nexport default {\n  computed: {\n    p () {\n      return this.msg?.payload || {}\n    }\n  }\n}\n</script>",
    "storeOutMessages": false,
    "passthru": false,
    "resendOnRefresh": true,
    "templateScope": "local",
    "x": 420,
    "y": 100,
    "wires": [[]]
  },
  {
    "id": "whi_mqtt_status",
    "type": "mqtt in",
    "z": "whi_tab",
    "name": "Status MQTT",
    "topic": "factory/inspection/status",
    "qos": "0",
    "datatype": "json",
    "broker": "whi_broker",
    "nl": false,
    "rap": true,
    "rh": 1,
    "inputs": 0,
    "x": 170,
    "y": 220,
    "wires": [["whi_status_display"]]
  },
  {
    "id": "whi_status_display",
    "type": "ui-template",
    "z": "whi_tab",
    "group": "whi_group_info",
    "name": "Status Display",
    "order": 1,
    "width": 6,
    "height": 10,
    "format": "<template>\n  <div class=\"whi-status-card\" :class=\"statusClass\">\n    <div class=\"whi-status-label\">Inspection Status</div>\n    <div class=\"whi-status-value\">{{ displayStatus }}</div>\n    <div class=\"whi-status-note\">{{ note }}</div>\n    <div class=\"whi-status-meta\">{{ displayTime }}</div>\n  </div>\n</template>\n<style>\n.whi-status-card {\n  width: 100%;\n  height: 100%;\n  min-height: 0;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  gap: 6px;\n  border-radius: 10px;\n  border: 2px solid #666;\n  background: #111;\n  color: #fff;\n  text-align: center;\n  padding: 12px;\n  box-sizing: border-box;\n}\n.whi-status-card.is-ok {\n  border-color: #22c55e;\n  background: rgba(34, 197, 94, 0.12);\n}\n.whi-status-card.is-nok {\n  border-color: #ef4444;\n  background: rgba(239, 68, 68, 0.12);\n}\n.whi-status-card.is-idle {\n  border-color: #6b7280;\n  background: rgba(107, 114, 128, 0.12);\n}\n.whi-status-label {\n  font-size: 12px;\n  color: #cbd5e1;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n.whi-status-value {\n  font-size: 32px;\n  font-weight: 800;\n  line-height: 1;\n}\n.whi-status-card.is-ok .whi-status-value {\n  color: #22c55e;\n}\n.whi-status-card.is-nok .whi-status-value {\n  color: #ef4444;\n}\n.whi-status-note {\n  font-size: 14px;\n  color: #e5e7eb;\n}\n.whi-status-meta {\n  font-size: 11px;\n  color: #9ca3af;\n}\n</style>\n<script>\nexport default {\n  computed: {\n    p () {\n      return this.msg?.payload || {}\n    },\n    statusClass () {\n      if (this.p.status === 'OK') return 'is-ok'\n      if (this.p.status === 'NOK') return 'is-nok'\n      return 'is-idle'\n    },\n    displayStatus () {\n      return this.p.status || 'EN ATTENTE'\n    },\n    note () {\n      if (Array.isArray(this.p.details) && this.p.details.length) {\n        return this.p.details[0]\n      }\n      if (this.p.note) {\n        return this.p.note\n      }\n      if (Array.isArray(this.p.missing_classes) && this.p.missing_classes.length) {\n        return `Missing: ${this.p.missing_classes.join(', ')}`\n      }\n      if (Array.isArray(this.p.misplaced_classes) && this.p.misplaced_classes.length) {\n        return `Misplaced: ${this.p.misplaced_classes.join(', ')}`\n      }\n      if (Array.isArray(this.p.failed_zone_ids) && this.p.failed_zone_ids.length) {\n        return `Failed zones: ${this.p.failed_zone_ids.join(', ')}`\n      }\n      if (this.p.anomaly_label) {\n        return this.p.anomaly_label\n      }\n      return 'Waiting for MQTT status...'\n    },\n    displayTime () {\n      if (!this.p.timestamp) return 'Waiting for retained status...'\n      const d = new Date(this.p.timestamp)\n      return Number.isNaN(d.getTime()) ? this.p.timestamp : d.toLocaleString('fr-FR')\n    }\n  }\n}\n</script>",
    "storeOutMessages": false,
    "passthru": false,
    "resendOnRefresh": true,
    "templateScope": "local",
    "x": 420,
    "y": 220,
    "wires": [[]]
  }
]
